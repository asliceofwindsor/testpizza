<script>
const sliceContent = {
  "Early Immigration": {
    title: "Early Immigration",
    text: "Early immigration brought Italian families to Windsor in the late nineteenth and early twentieth centuries. These newcomers established tight-knit communities that relied on food, family businesses, and shared traditions to survive economic uncertainty and discrimination.",
    link: "Early Immigration.html"
  },
  "The Creation of Windsor Pizzas": {
    title: "The Creation of Windsor Pizzas",
    text: "Italian-owned bakeries, groceries, and pizzerias became community hubs. These family-run businesses preserved cultural traditions while contributing to Windsor’s local economy and shaping a distinctly Italian-Canadian identity.",
    link: "The Creation of Windsor Pizza.html"
  },
  "Windsor Pizzerias": {
    title: "Windsor Pizzerias",
    text: "Windsor-style pizza emerged as a recognizable product defined by shredded pepperoni, canned mushrooms, Galati cheese, and a thin crust. Its consistency and flavour helped it gain national and international recognition.",
    link: "Windsor Pizzerias.html"
  },
  "Sticking to the Recipe": {
    title: "Sticking to the Recipe",
    text: "Unlike large American pizza chains, Windsor pizzerias resisted standardization. Maintaining traditional methods reinforced authenticity and distinguished local businesses from corporate competitors.",
    link: "Sticking to the Recipe.html"
  },
  "Maintaining a Legacy": {
    title: "Maintaining a Legacy",
    text: "Today, Windsor pizza represents more than food. It symbolizes family labour, cultural memory, and resistance to American commercial dominance in a border city.",
    link: "Maintaing a Legacy.html"
  },
  "About": {
    title: "About This Project",
    text: "The Windsor Pizza Project explores how food history can reveal broader stories about migration, identity, and local economic resilience.",
    link: "about.html"
  }
};

const slices = document.querySelectorAll(".slice");
const infoTitle = document.getElementById("info-title");
const infoText = document.getElementById("info-text");
const infoButton = document.getElementById("info-button");

slices.forEach(slice => {
  slice.addEventListener("click", () => {
    const content = sliceContent[slice.dataset.info];
    if (content) {
      infoTitle.textContent = content.title;
      infoText.textContent = content.text;
      infoButton.href = content.link;
      infoButton.style.display = "inline-block";
    }
  });
});
</script>


